# Leave empty when frontend and API are on the same domain (recommended).
# Example same-domain: REACT_APP_API_BASE_URL=
# Example API subdomain: REACT_APP_API_BASE_URL=https://api.yourdomain.com
REACT_APP_API_BASE_URL=

REACT_APP_API_VERSION=1.0.0
REACT_APP_CLIENT_VERSION=1.0.0

# Google Sign-In (must match backend GOOGLE_CLIENT_ID authorized origins)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Optional: Leopards courier tracking
# REACT_APP_LEOPARDS_API_BASE=
# REACT_APP_LEOPARDS_CLIENT_ID=
# REACT_APP_LEOPARDS_CLIENT_SECRET=

# Server
PORT=4000
NODE_ENV=production

# MongoDB Atlas (required — Hostinger does not run MongoDB)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/carriya?retryWrites=true&w=majority
MONGODB_DB=carriya

# Auth
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Your live site URL(s), comma-separated if you use www + apex
FRONTEND_URL=https://yourdomain.com,https://www.yourdomain.com

# Cookie mode: lax = same domain (recommended), none = cross-subdomain (api.yourdomain.com)
COOKIE_SAME_SITE=lax

# Optional: serve React build from Node (use nginx instead on VPS)
# SERVE_FRONTEND=true

# Initial admin (created once on first boot if no admin exists)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_strong_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Google OAuth (login with Google)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Cloudinary (product & seller image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (SMTP — use Hostinger email or Gmail app password)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@yourdomain.com
SMTP_PASS=your_email_password
SMTP_FROM_NAME=Carriya
SMTP_FROM_ADDRESS=hello@yourdomain.com

# Optional: WhatsApp OTP
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=

# Optional: settlement cron
# SETTLEMENT_CRON_SCHEDULE=0 2 * * *
# SETTLEMENT_CRON_TZ=Asia/Karachi

# Optional: Redis rate limiting
# REDIS_URL=
